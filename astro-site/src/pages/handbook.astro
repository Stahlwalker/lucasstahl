	}

	:global([data-theme="light"]) .nav-link::before {
		color: #2563eb;
	}

	:global([data-theme="light"]) .nav-link:hover,
	:global([data-theme="light"]) .nav-link.active {
		color: #15803d;
		background: rgba(21, 128, 61, 0.08);
	}

	:global([data-theme="light"]) .handbook-page-content {
		background: #ffffff;
	}

	:global([data-theme="light"]) .handbook-section h2 {
		color: #2563eb;
		border-bottom-color: #e2e8f0;
	}

	:global([data-theme="light"]) .handbook-section h2::before {
		color: #2563eb;
	}

	:global([data-theme="light"]) .handbook-section :global(h3) {
		color: #2563eb;
	}

	:global([data-theme="light"]) .handbook-section :global(h3::before) {
		color: #2563eb;
	}

	:global([data-theme="light"]) .handbook-section :global(p),
	:global([data-theme="light"]) .handbook-section :global(li) {
