	:global([data-theme="light"]) .cta-content h3 {
		color: #2563eb;
	}

	:global([data-theme="light"]) .cta-content h3::before {
		color: #2563eb;
	}

	:global([data-theme="light"]) .cta-content p {
		color: #475569;
	}

	:global([data-theme="light"]) .cta-button-primary {
		background: linear-gradient(135deg, #2563eb, #3b82f6);
		color: #ffffff;
		border-color: transparent;
	}

	:global([data-theme="light"]) .cta-button-primary:hover {
		box-shadow: 0 6px 25px rgba(37, 99, 235, 0.3);
	}

	:global([data-theme="light"]) .cta-button-secondary {
		background: #f8fafc;
		color: #475569;
		border-color: rgba(0, 0, 0, 0.2);
	}

	:global([data-theme="light"]) .cta-button-secondary:hover {
		background: #f1f5f9;
		border-color: #2563eb;
	}

	:global([data-theme="light"]) .copy-all-sections-btn {
		border-color: #2563eb;
		color: #2563eb;
	}

	:global([data-theme="light"]) .copy-all-sections-btn:hover {
		background: rgba(37, 99, 235, 0.08);
	}

	:global([data-theme="light"]) .copy-all-sections-btn.copied {
		background: rgba(21, 128, 61, 0.08);
		border-color: #15803d;
		color: #15803d;
	}

	/* Link styling — markdown-rendered <a> needs :global() to escape scope */
	.handbook-section :global(a) {
		color: #f472b6;
		text-decoration: underline;
		transition: opacity 0.2s ease;
	}

	.handbook-section :global(a:hover) {
		opacity: 0.8;
	}

	:global([data-theme="light"] .handbook-section a) {
		color: #be185d !important;
	}
</style>

<script>
	// Highlight active section in nav
	const observer = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				const id = entry.target.getAttribute('id');
				document.querySelectorAll('.nav-link').forEach(link => {
					link.classList.remove('active');
					if (link.getAttribute('href') === `#${id}`) {
						link.classList.add('active');
					}
				});
			}
		});
	}, { threshold: 0.5 });

	document.querySelectorAll('.handbook-section').forEach(section => {
		observer.observe(section);
	});

	// Copy all sections from Goals through Metrics
	const copyAllBtn = document.getElementById('copyAllBtn');
	if (copyAllBtn) {
		copyAllBtn.addEventListener('click', async () => {
			const sectionIds = ['goals', 'strategy', 'journey', 'personas', 'messaging', 'campaigns', 'content', 'community', 'metrics'];
			let allContent = '';

			sectionIds.forEach(id => {
				const section = document.getElementById(id);
				if (section) {
					// Get section title
					const title = section.querySelector('h2')?.textContent.trim() || '';
					allContent += `${title}\n${'='.repeat(title.length)}\n\n`;

					// Get all paragraphs, lists, and callouts
					const elements = section.querySelectorAll('p, ul, ol, .callout, h3');
					elements.forEach(el => {
						if (el.tagName === 'H3') {
							allContent += `\n${el.textContent.trim()}\n${'-'.repeat(el.textContent.trim().length)}\n\n`;
						} else if (el.tagName === 'UL' || el.tagName === 'OL') {
							const items = el.querySelectorAll('li');
							items.forEach(li => {
								allContent += `• ${li.textContent.trim()}\n`;
							});
							allContent += '\n';
						} else {
							allContent += `${el.textContent.trim()}\n\n`;
						}
					});

					allContent += '\n---\n\n';
				}
			});

			try {
				await navigator.clipboard.writeText(allContent);

				// Visual feedback — swap SVG via hidden source spans
				const copySrc = document.getElementById('svg-icon-copy');
				const checkSrc = document.getElementById('svg-icon-check');
				if (checkSrc) copyAllBtn.innerHTML = checkSrc.innerHTML;
				copyAllBtn.classList.add('copied');

				setTimeout(() => {
					if (copySrc) copyAllBtn.innerHTML = copySrc.innerHTML;
					copyAllBtn.classList.remove('copied');
				}, 2000);
			} catch (err) {
				console.error('Failed to copy:', err);
			}
		});
	}
</script>
