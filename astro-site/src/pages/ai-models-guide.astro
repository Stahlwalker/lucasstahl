---
import Layout from '../layouts/Layout.astro';

// Quick Reference Data
const quickReference = [
	{ model: "GPT-5.x", company: "OpenAI", bestFor: "General purpose", differentiator: "Dynamic routing picks the right sub-model per request", color: "#10b981" },
	{ model: "Claude 4.6", company: "Anthropic", bestFor: "Coding & reasoning", differentiator: "Top human-preference scores; agentic autonomy", color: "#c084fc" },
	{ model: "Gemini 3.x", company: "Google DeepMind", bestFor: "Multimodal", differentiator: "Best benchmark breadth; strong pricing; Workspace integration", color: "#60a5fa" },
	{ model: "Grok 4.x", company: "xAI", bestFor: "Real-time info", differentiator: "Live X/Twitter data; multi-agent parallel reasoning", color: "#f97316" },
	{ model: "Llama 4", company: "Meta", bestFor: "Open-source", differentiator: "10M token context; fully self-hostable", color: "#06b6d4" },
	{ model: "DeepSeek V3/R1", company: "DeepSeek", bestFor: "Cost efficiency", differentiator: "Frontier performance trained for under $6M; open source", color: "#facc15" },
	{ model: "Mistral Large", company: "Mistral", bestFor: "EU compliance", differentiator: "Enterprise-safe; strong open-weight models for regulated industries", color: "#818cf8" },
	{ model: "Qwen 3", company: "Alibaba", bestFor: "Multilingual", differentiator: "119 languages; models from 0.5B to 1T+ parameters", color: "#f472b6" },
];

// Frontier Models
const frontierModels = [
	{
		name: "GPT-5.x Series",
		company: "OpenAI",
		location: "San Francisco",
		color: "#10b981",
		tagline: "The versatile all-rounder with dynamic internal routing.",
		bullets: [
			"GPT-5.4 is the current flagship with a 1M token context window",
			"Uses an internal router to select the right sub-model per request in real time",
			"Lowest syntax error rate in code generation among frontier models",
			"Strong at documentation, unit tests, and complex SQL queries"
		],
		bestFor: "Rapid prototyping, general-purpose tasks, API automation"
	},
	{
		name: "Claude 4.6 Family",
		company: "Anthropic",
		location: "San Francisco",
		color: "#c084fc",
		tagline: "The developer favorite for coding, reasoning, and safety.",
		bullets: [
			"Opus 4.6 (flagship), Sonnet 4.6 (best value), Haiku 4.5 (fast/cheap)",
			"Leads human-preference leaderboards; strong ARC-AGI-2 scores",
			"Agentic capabilities: autonomous multi-step coding tasks",
			"Known for safety, steerability, and high-quality long-form writing"
		],
		bestFor: "Software development, agentic workflows, analysis, writing"
	},
	{
		name: "Gemini 3.x",
		company: "Google DeepMind",
		location: "Mountain View",
		color: "#60a5fa",
		tagline: "Multimodal powerhouse with top benchmark breadth.",
		bullets: [
			"Gemini 3.1 Pro leads the Artificial Analysis Intelligence Index",
			"Native multimodal: processes text, images, audio, and video natively",
			"1M token context window; deep Google Workspace integration",
			"Strong value at $2/$12 per million input/output tokens"
		],
		bestFor: "Multimodal apps, Google Workspace users, cost-conscious teams"
	},
	{
		name: "Grok 4.x",
		company: "xAI",
		location: "Austin",
		color: "#f97316",
		tagline: "Real-time data meets raw reasoning power.",
		bullets: [
			"Grok 4 Heavy uses multi-agent parallel reasoning for hard problems",
			"Real-time integration with X (Twitter) for current events",
			"Scored 100% on AIME 2025 math competition (Heavy variant)",
			"Less filtered personality; positioned as an alternative to corporate AI"
		],
		bestFor: "Real-time info, math/science, users who want less guardrails"
	}
];

// Open Source Models
const openSourceModels = [
	{
		name: "Llama 4",
		company: "Meta",
		location: "Menlo Park",
		color: "#06b6d4",
		tagline: "The leading open-source model family.",
		bullets: [
			"Llama 4 Scout: industry-leading 10M token context window",
			"Fully open weights; can be self-hosted for complete data control",
			"Performance competitive with paid frontier models",
			"Requires powerful hardware for full-scale deployment"
		],
		bestFor: "Self-hosting, privacy-sensitive orgs, custom fine-tuning"
	},
	{
		name: "DeepSeek V3 / R1",
		company: "DeepSeek",
		location: "Hangzhou, China",
		color: "#facc15",
		tagline: "Frontier performance at a fraction of the cost.",
		bullets: [
			"671B parameter MoE model famously trained for under $6M",
			"R1 variant excels at transparent, step-by-step reasoning",
			"Open-source with competitive benchmark scores",
			"Can face occasional service reliability challenges"
		],
		bestFor: "Budget-conscious teams, math/reasoning, open-source self-hosting"
	},
	{
		name: "Mistral Large 3",
		company: "Mistral AI",
		location: "Paris, France",
		color: "#818cf8",
		tagline: "The enterprise-safe European choice.",
		bullets: [
			"Strong open-weight models designed for EU AI Act compliance",
			"Default choice for regulated industries (finance, healthcare, gov)",
			"Good multilingual support, especially European languages",
			"Balances capability with privacy and sovereignty requirements"
		],
		bestFor: "EU-regulated enterprises, privacy-first deployments"
	},
	{
		name: "Qwen 3",
		company: "Alibaba Cloud",
		location: "Hangzhou, China",
		color: "#f472b6",
		tagline: "The multilingual giant.",
		bullets: [
			"Supports 119 languages with hybrid Mixture-of-Experts architecture",
			"Parameter scales exceeding 1 trillion; 0.5B to 235B available",
			"Matches or beats GPT-4 on many benchmarks with less compute",
			"Specialized variants for vision, coding, math, and long context"
		],
		bestFor: "International businesses, multilingual apps, flexible deployment"
	}
];

// Image & Video Models
const imageVideoModels = [
	{ name: "Midjourney v7", company: "Midjourney", bestFor: "Artistic, stylized visuals with strong aesthetic control" },
	{ name: "Imagen 4", company: "Google", bestFor: "Photorealistic composition, spelling, and typography accuracy" },
	{ name: "Nano Banana 2", company: "Google", bestFor: "Fast AI image editing, remixing, and style transfers; built on Gemini Flash" },
	{ name: "DALL-E 4", company: "OpenAI", bestFor: "Integrated with ChatGPT; strong prompt adherence" },
	{ name: "Stable Diffusion 3.5", company: "Stability AI", bestFor: "Open-source; self-hostable; highly customizable" },
];

// Scenario Cards — real tasks mapped to models
const scenarios = [
	{
		title: "Building Software",
		color: "#c084fc",
		tasks: [
			{ task: "Build a full-stack app from scratch", model: "Claude 4.6", color: "#c084fc" },
			{ task: "Debug a complex codebase", model: "Claude 4.6", color: "#c084fc" },
			{ task: "Generate unit tests and docs", model: "GPT-5.x", color: "#10b981" },
			{ task: "Rapid UI prototyping", model: "GPT-5.x", color: "#10b981" },
		]
	},
	{
		title: "Research & Analysis",
		color: "#60a5fa",
		tasks: [
			{ task: "Analyze a long PDF or contract", model: "Gemini 3.x", color: "#60a5fa" },
			{ task: "Summarize a YouTube video", model: "Gemini 3.x", color: "#60a5fa" },
			{ task: "Get real-time data on a trending topic", model: "Grok 4.x", color: "#f97316" },
			{ task: "Deep competitive research", model: "Claude 4.6", color: "#c084fc" },
		]
	},
	{
		title: "Creative & Visual",
		color: "#f472b6",
		tasks: [
			{ task: "Create stylized hero images", model: "Midjourney v7", color: "#f472b6" },
			{ task: "Generate photorealistic product shots", model: "Imagen 4", color: "#60a5fa" },
			{ task: "Edit and remix existing images", model: "Nano Banana 2", color: "#60a5fa" },
			{ task: "Generate a short video from a prompt", model: "Veo 3 / Sora", color: "#818cf8" },
		]
	},
	{
		title: "Data & Math",
		color: "#f97316",
		tasks: [
			{ task: "Solve complex math problems step-by-step", model: "Grok 4.x", color: "#f97316" },
			{ task: "Write and optimize SQL queries", model: "GPT-5.x", color: "#10b981" },
			{ task: "Transparent chain-of-thought reasoning", model: "DeepSeek R1", color: "#facc15" },
			{ task: "Analyze spreadsheet data", model: "Gemini 3.x", color: "#60a5fa" },
		]
	},
	{
		title: "Self-Hosting & Privacy",
		color: "#06b6d4",
		tasks: [
			{ task: "Run a model on your own infrastructure", model: "Llama 4", color: "#06b6d4" },
			{ task: "Fine-tune for a domain-specific task", model: "Llama 4", color: "#06b6d4" },
			{ task: "Deploy in EU-regulated environments", model: "Mistral Large", color: "#818cf8" },
			{ task: "Budget-friendly open-source alternative", model: "DeepSeek V3", color: "#facc15" },
		]
	},
	{
		title: "Writing & Communication",
		color: "#10b981",
		tasks: [
			{ task: "Write long-form technical content", model: "Claude 4.6", color: "#c084fc" },
			{ task: "Draft emails and business writing", model: "GPT-5.x", color: "#10b981" },
			{ task: "Translate content across 100+ languages", model: "Qwen 3", color: "#f472b6" },
			{ task: "Summarize meeting transcripts", model: "Gemini 3.x", color: "#60a5fa" },
		]
	},
];
---

<Layout
	title="AI Models Guide 2026"
	description="A quick-reference to the major AI models in 2026 — GPT-5, Claude 4.6, Gemini 3, Grok 4, Llama 4, DeepSeek, Mistral, and Qwen 3. Who makes them, what they do best, and when to use each one."
	ogTitle="AI Models Guide 2026 — Every Major Model Compared"
	ogDescription="A quick-reference to the major AI models in 2026. GPT-5, Claude, Gemini, Grok, Llama, DeepSeek, Mistral, Qwen — compared by use case."
	canonicalUrl="https://lukestahl.io/ai-models-guide/"
	hideHandbookButton={true}
>
	<!-- JSON-LD: Article structured data -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": "AI Models Guide 2026 — Every Major Model Compared",
		"description": "A quick-reference to the major AI models in 2026. GPT-5, Claude 4.6, Gemini 3, Grok 4, Llama 4, DeepSeek, Mistral, and Qwen 3 compared by use case.",
		"author": {
			"@type": "Person",
			"name": "Luke Stahl",
			"url": "https://lukestahl.io/"
		},
		"publisher": {
			"@type": "Person",
			"name": "Luke Stahl",
			"url": "https://lukestahl.io/"
		},
		"datePublished": "2026-03-10",
		"dateModified": "2026-03-10",
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": "https://lukestahl.io/ai-models-guide/"
		},
		"keywords": "AI models, GPT-5, Claude 4.6, Gemini 3, Grok 4, Llama 4, DeepSeek, Mistral, Qwen 3, AI comparison, LLM guide 2026"
	})} />

	<!-- JSON-LD: BreadcrumbList -->
	<script type="application/ld+json" set:html={JSON.stringify({
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		"itemListElement": [
			{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lukestahl.io/" },
			{ "@type": "ListItem", "position": 2, "name": "AI Models Guide", "item": "https://lukestahl.io/ai-models-guide/" }
		]
	})} />

	<div class="guide-shell">
		<!-- Ambient background layers -->
		<div class="bg-glow bg-glow--hero" aria-hidden="true"></div>
		<div class="bg-glow bg-glow--mid" aria-hidden="true"></div>


		<main class="guide-main">
			<!-- Hero -->
			<section class="hero">
				<h1 class="hero-title">AI Models<br/><span class="hero-title-accent">Guide</span></h1>
				<p class="hero-subtitle">A quick-reference to the major AI models, who makes them, and what they do best.</p>
				<div class="hero-badge">Updated March 2026</div>
			</section>

			<!-- Quick Reference -->
			<section class="section" id="quick-reference">
				<div class="section-label">
					<span class="section-label-dot"></span>
					Quick Reference
				</div>
				<div class="ref-table-wrap">
					<table class="ref-table">
						<thead>
							<tr>
								<th>Model</th>
								<th>Company</th>
								<th>Best For</th>
								<th>Key Differentiator</th>
							</tr>
						</thead>
						<tbody>
							{quickReference.map(row => (
								<tr>
									<td>
										<span class="ref-dot" style={`--dot-color: ${row.color}`}></span>
										<span class="ref-model">{row.model}</span>
									</td>
									<td class="ref-company">{row.company}</td>
									<td><span class="ref-badge" style={`--badge-color: ${row.color}`}>{row.bestFor}</span></td>
									<td class="ref-diff">{row.differentiator}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>

			<!-- Frontier LLMs -->
			<section class="section" id="frontier">
				<div class="section-label">
					<span class="section-label-dot"></span>
					Frontier Language Models
				</div>
				<div class="model-grid model-grid--2">
					{frontierModels.map(model => (
						<article class="model-card" style={`--card-accent: ${model.color}`}>
							<div class="model-card-head">
								<div class="model-card-indicator"></div>
								<div>
									<h3 class="model-card-name">{model.name}</h3>
									<span class="model-card-meta">{model.company} &middot; {model.location}</span>
								</div>
							</div>
							<p class="model-card-tagline">{model.tagline}</p>
							<ul class="model-card-list">
								{model.bullets.map(b => <li>{b}</li>)}
							</ul>
							<div class="model-card-footer">
								<span class="model-card-best">Best for: {model.bestFor}</span>
							</div>
						</article>
					))}
				</div>
			</section>

			<!-- Open Source -->
			<section class="section" id="open-source">
				<div class="section-label">
					<span class="section-label-dot"></span>
					Open Source &amp; Cost-Efficient
				</div>
				<div class="model-grid model-grid--2">
					{openSourceModels.map(model => (
						<article class="model-card" style={`--card-accent: ${model.color}`}>
							<div class="model-card-head">
								<div class="model-card-indicator"></div>
								<div>
									<h3 class="model-card-name">{model.name}</h3>
									<span class="model-card-meta">{model.company} &middot; {model.location}</span>
								</div>
							</div>
							<p class="model-card-tagline">{model.tagline}</p>
							<ul class="model-card-list">
								{model.bullets.map(b => <li>{b}</li>)}
							</ul>
							<div class="model-card-footer">
								<span class="model-card-best">Best for: {model.bestFor}</span>
							</div>
						</article>
					))}
				</div>
			</section>

			<!-- Image & Video -->
			<section class="section" id="image-video">
				<div class="section-label">
					<span class="section-label-dot"></span>
					Image &amp; Video Generation
				</div>
				<div class="media-grid">
					{imageVideoModels.map(m => (
						<div class="media-card">
							<h4 class="media-card-name">{m.name}</h4>
							<span class="media-card-company">{m.company}</span>
							<p class="media-card-desc">{m.bestFor}</p>
						</div>
					))}
				</div>
				<p class="media-note">
					<strong>Video generation leaders:</strong> Google Veo 3 (physics simulation + native audio), Sora (OpenAI), and Runway Gen-4 (creative/cinematic).
				</p>
			</section>

			<!-- When to Use What -->
			<section class="section" id="use-cases">
				<div class="section-label">
					<span class="section-label-dot"></span>
					When to Use What
				</div>
				<div class="scenario-grid">
					{scenarios.map(scenario => (
						<div class="scenario-card" style={`--scenario-accent: ${scenario.color}`}>
							<h3 class="scenario-title">{scenario.title}</h3>
							<ul class="scenario-list">
								{scenario.tasks.map(t => (
									<li class="scenario-task">
										<span class="scenario-task-label">{t.task}</span>
										<span class="scenario-task-model" style={`--dm-color: ${t.color}`}>{t.model}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</section>

			<!-- Closing -->
			<section class="section closing">
				<p class="closing-text">There is no single "best" model in 2026. The landscape has shifted from a winner-take-all race to specialized excellence. Match the model to the task.</p>
			</section>
		</main>

	</div>
</Layout>

<style>
	/* ============================================
	   AI MODELS GUIDE — "Neural Observatory"
	   Dark-first, glassy, luminous accents
	   ============================================ */

	/* --- Shell & Ambient Layers --- */
	.guide-shell {
		--guide-bg: #07070e;
		--guide-surface: rgba(255, 255, 255, 0.025);
		--guide-surface-hover: rgba(255, 255, 255, 0.045);
		--guide-border: rgba(255, 255, 255, 0.07);
		--guide-border-hover: rgba(255, 255, 255, 0.14);
		--guide-text: #ededf0;
		--guide-text-dim: #a8a8bc;
		--guide-text-faint: #727286;

		min-height: 100vh;
		background: transparent;
		color: var(--guide-text);
		position: relative;
		overflow-x: hidden;
		font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
	}

	.bg-glow {
		position: fixed;
		pointer-events: none;
		z-index: 0;
		border-radius: 50%;
		filter: blur(100px);
	}

	.bg-glow--hero {
		width: 800px;
		height: 600px;
		top: -200px;
		left: 50%;
		transform: translateX(-50%);
		background: radial-gradient(ellipse, rgba(139, 92, 246, 0.08) 0%, rgba(59, 130, 246, 0.04) 50%, transparent 70%);
	}

	.bg-glow--mid {
		width: 600px;
		height: 400px;
		top: 60%;
		right: -200px;
		background: radial-gradient(ellipse, rgba(6, 182, 212, 0.05) 0%, transparent 70%);
	}

	.guide-shell > *:not(.bg-glow) {
		position: relative;
		z-index: 1;
	}


	/* --- Main --- */
	.guide-main {
		max-width: 1100px;
		margin: 0 auto;
		padding: 0 2rem 4rem;
	}

	/* --- Hero --- */
	.hero {
		padding: 5rem 0 3rem;
		text-align: center;
	}

	.hero-title {
		font-family: 'Fira Code', monospace;
		font-size: clamp(2.4rem, 5.5vw, 4rem);
		font-weight: 700;
		line-height: 1.1;
		letter-spacing: -0.03em;
		color: var(--guide-text);
		margin: 0 0 1.5rem;
	}

	.hero-title-accent {
		background: linear-gradient(135deg, #c084fc 0%, #60a5fa 40%, #06b6d4 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: 1.1rem;
		line-height: 1.65;
		color: var(--guide-text-dim);
		max-width: 520px;
		margin: 0 auto 1.75rem;
	}

	.hero-badge {
		display: inline-block;
		font-family: 'Fira Code', monospace;
		font-size: 0.75rem;
		font-weight: 500;
		color: #60a5fa;
		border: 1px solid rgba(96, 165, 250, 0.3);
		background: rgba(96, 165, 250, 0.08);
		border-radius: 100px;
		padding: 0.35rem 1rem;
		letter-spacing: 0.04em;
	}

	/* --- Section Labels --- */
	.section {
		margin-top: 4rem;
	}

	.section-label {
		font-family: 'Fira Code', monospace;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--guide-text-dim);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		display: flex;
		align-items: center;
		gap: 0.6rem;
		margin-bottom: 1.75rem;
	}

	.section-label-dot {
		width: 6px;
		height: 6px;
		border-radius: 50%;
		background: #60a5fa;
		box-shadow: 0 0 8px rgba(96, 165, 250, 0.5);
	}

	/* --- Quick Reference Table --- */
	.ref-table-wrap {
		overflow-x: auto;
		border: 1px solid var(--guide-border);
		border-radius: 12px;
		background: var(--guide-bg);
	}

	.ref-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.88rem;
	}

	.ref-table thead th {
		font-family: 'Fira Code', monospace;
		font-size: 0.72rem;
		font-weight: 600;
		color: var(--guide-text-dim);
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 1rem 1.25rem;
		text-align: left;
		border-bottom: 1px solid var(--guide-border);
		white-space: nowrap;
	}

	.ref-table tbody tr {
		transition: background 0.15s;
	}

	.ref-table tbody tr:hover {
		background: rgba(255, 255, 255, 0.025);
	}

	.ref-table tbody td {
		padding: 0.85rem 1.25rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.03);
		vertical-align: middle;
	}

	.ref-table tbody tr:last-child td {
		border-bottom: none;
	}

	.ref-dot {
		display: inline-block;
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background: var(--dot-color);
		box-shadow: 0 0 6px color-mix(in srgb, var(--dot-color) 50%, transparent);
		margin-right: 0.6rem;
		vertical-align: middle;
	}

	.ref-model {
		font-weight: 600;
		color: var(--guide-text);
	}

	.ref-company {
		color: var(--guide-text-dim);
	}

	.ref-badge {
		display: inline-block;
		font-family: 'Fira Code', monospace;
		font-size: 0.72rem;
		font-weight: 500;
		padding: 0.25rem 0.65rem;
		border-radius: 100px;
		background: color-mix(in srgb, var(--badge-color) 12%, transparent);
		color: var(--badge-color);
		white-space: nowrap;
	}

	.ref-diff {
		color: var(--guide-text-dim);
		font-size: 0.84rem;
	}

	/* --- Model Cards --- */
	.model-grid {
		display: grid;
		gap: 1.25rem;
	}

	.model-grid--2 {
		grid-template-columns: repeat(2, 1fr);
	}

	.model-card {
		background: var(--guide-bg);
