							<h3 class="scenario-title">{scenario.title}</h3>
							<ul class="scenario-list">
								{scenario.tasks.map(t => (
									<li class="scenario-task">
										<span class="scenario-task-label">{t.task}</span>
										<span class="scenario-task-model" style={`--dm-color: ${t.color}`}>{t.model}</span>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</section>

			<!-- Closing -->
			<section class="section closing">
				<p class="closing-text">There is no single "best" model in 2026. The landscape has shifted from a winner-take-all race to specialized excellence. Match the model to the task.</p>
				<div class="closing-radar">
					<div class="radar-scope" aria-hidden="true">
						<div class="radar-arc radar-arc--1"></div>
						<div class="radar-arc radar-arc--2"></div>
						<div class="radar-arc radar-arc--3"></div>
						<div class="radar-beam"></div>
						<div class="radar-base"></div>
						<span class="radar-blip radar-blip--1"></span>
						<span class="radar-blip radar-blip--2"></span>
						<span class="radar-blip radar-blip--3"></span>
						<span class="radar-blip radar-blip--4"></span>
					</div>
					<p class="radar-text">Sourced directly from company websites and documentation. Updated weekly.</p>
				</div>
			</section>
		</main>

	</div>
</Layout>

