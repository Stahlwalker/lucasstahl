---
import Layout from '../layouts/Layout.astro';
import brainSvg from '../icons/brain-solid-full.svg?raw';
import newspaperSvg from '../icons/newspaper-solid-full.svg?raw';
import walletSvg from '../icons/wallet-solid-full.svg?raw';
import golfBallTeeSvg from '../icons/golf-ball-tee-solid-full.svg?raw';
import gamepadSvg from '../icons/gamepad-solid-full.svg?raw';
import footballSvg from '../icons/football-solid-full.svg?raw';
import magnifyingGlassSvg from '../icons/magnifying-glass-solid-full.svg?raw';
import utensilsSvg from '../icons/utensils-solid-full.svg?raw';
import flowerTulipSvg from '../icons/flower-tulip-solid-full.svg?raw';
import codeSvg from '../icons/code-solid-full.svg?raw';
import locationDotSvg from '../icons/location-dot-solid-full.svg?raw';
import globeSvg from '../icons/globe-solid-full.svg?raw';
import userSvg from '../icons/user-solid-full.svg?raw';
import arrowOutSvg from '../icons/arrow-up-right-from-square-solid-full.svg?raw';
import swatchbookSvg from '../icons/swatchbook-solid-full.svg?raw';
import githubSvg from '../icons/github-brands-solid-full.svg?raw';
import sunSvg from '../icons/sun-solid-full.svg?raw';
import fileLinesSvg from '../icons/file-lines-solid-full.svg?raw';
import boxesStackedSvg from '../icons/boxes-stacked-solid-full.svg?raw';
import copySvg from '../icons/copy-regular-full.svg?raw';
---

<Layout
	title="Builds - Luke Stahl"
	description="Builds from Luke Stahl — showcasing work across developer marketing, product strategy, and modern web development."
	canonicalUrl="https://lukestahl.io/builds/"
	ogTitle="Builds - Luke Stahl"
	ogDescription="A collection of projects, experiments, and digital experiences built with React, Next.js, TypeScript, and modern web technologies."
	additionalCss={["/assets/css/builds.css"]}
	inlineCriticalCSS={true}
	loadFontAwesome={false}
>
	<!-- Builds Hero Section -->
	<section class="builds-hero">
		<div class="section-container">
			<h1 class="builds-hero-title">
				<span class="code-bracket">&lt;</span>
				Builds
				<span class="code-bracket">/&gt;</span>
			</h1>
			<p class="builds-hero-subtitle">A collection of projects, experiments, and digital experiences</p>
		</div>
	</section>

	<!-- Solar Framework Feature Section -->
	<section class="solar-feature-section">
		<div class="solar-inner">
			<div class="solar-left">
				<div class="solar-eyebrow">
					<span class="solar-icon-svg" set:html={sunSvg} />
					<span class="solar-label">MY FRAMEWORK</span>
				</div>
				<h2 class="solar-headline">Solar</h2>
				<p class="solar-desc">
					A JavaScript UI framework designed for AI-generated code. Explicit contracts, a component registry, and structured errors an agent can parse and self-correct. Built so the output is predictably correct, not just probably correct.
				</p>

				<div class="solar-install">
					<div class="solar-code-block">
						<span class="solar-code-prompt" id="solar-prompt">$</span>
						<code class="solar-code-cmd" id="solar-cmd">npm create solarbuild@latest my-app</code>
						<button class="solar-copy-btn" id="solar-copy-btn" aria-label="Copy install command">
							<span class="solar-copy-icon" set:html={copySvg} />
							<span class="solar-copy-label" id="solar-copy-label">Copy</span>
						</button>
					</div>
				</div>

				<div class="solar-links">
					<a href="https://docs.solarbuild.dev/" target="_blank" rel="noopener noreferrer" class="solar-link solar-link--primary">
						<span class="solar-link-icon" set:html={fileLinesSvg} />
						Read the docs
						<span class="solar-link-arrow" set:html={arrowOutSvg} />
					</a>
					<a href="https://github.com/Stahlwalker/framework-solar" target="_blank" rel="noopener noreferrer" class="solar-link">
						<span class="solar-link-icon" set:html={githubSvg} />
						GitHub
						<span class="solar-link-arrow" set:html={arrowOutSvg} />
					</a>
					<a href="https://npmjs.com/package/solarbuild" target="_blank" rel="noopener noreferrer" class="solar-link">
						<span class="solar-link-icon" set:html={boxesStackedSvg} />
						npm
						<span class="solar-link-arrow" set:html={arrowOutSvg} />
					</a>
				</div>
			</div>

			<div class="solar-terminal" aria-hidden="true">
				<div class="solar-terminal-chrome">
					<span class="solar-dot solar-dot--red"></span>
					<span class="solar-dot solar-dot--yellow"></span>
					<span class="solar-dot solar-dot--green"></span>
					<span class="solar-terminal-title">solar — demo.js</span>
				</div>
				<div class="solar-terminal-body">
<pre class="solar-terminal-pre"><span class="t-brand">████ ████ █    ██  ███
█    █  █ █   █  █ █  █
████ █  █ █   ████ ███
   █ █  █ █   █  █ █ █
████ ████ ████ ██  █  █</span>

<span class="t-prompt">$</span> npm create solarbuild@latest my-app
  <span class="t-success">✓</span> Created project
  <span class="t-success">✓</span> Installed dependencies

<span class="t-prompt">$</span> cd my-app &amp;&amp; npm run dev
  ➜  Local: <span class="t-str">http://localhost:3456/</span></pre>
				</div>
			</div>
		</div>
	</section>

	<script>
		// Tab switcher
		const commands = {
			npm: { prompt: '$', cmd: 'npm create solarbuild@latest my-app' },
			cdn: { prompt: '>', cmd: 'https://cdn.jsdelivr.net/gh/Stahlwalker/framework-solar@main/framework/index.js' },
		};
		document.querySelectorAll('.solar-tab').forEach(tab => {
			tab.addEventListener('click', () => {
				document.querySelectorAll('.solar-tab').forEach(t => t.classList.remove('is-active'));
				tab.classList.add('is-active');
				const key = tab.dataset.tab;
				const promptEl = document.getElementById('solar-prompt');
				const cmdEl = document.getElementById('solar-cmd');
				if (promptEl) promptEl.textContent = commands[key].prompt;
				if (cmdEl) cmdEl.textContent = commands[key].cmd;
			});
		});

		// Copy button
		const btn = document.getElementById('solar-copy-btn');
		const label = document.getElementById('solar-copy-label');
		btn?.addEventListener('click', () => {
			const cmd = document.getElementById('solar-cmd')?.textContent ?? '';
			navigator.clipboard.writeText(cmd).then(() => {
				btn.classList.add('is-copied');
				if (label) label.textContent = 'Copied!';
				setTimeout(() => {
					btn.classList.remove('is-copied');
					if (label) label.textContent = 'Copy';
				}, 2000);
			});
		});
	</script>

	<!-- Builds Grid Section -->
	<section class="builds-section">
		<div class="section-container">
			<div class="builds-grid">

				<!-- Project: Developer Marketing Claude Skill (Featured) -->
				<article class="build-card featured-project">
