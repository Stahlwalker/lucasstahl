import seoData from '../data/seo-results.json';
import webflowLight from '../assets/images/light/Webflow_light.png';
import webflowDark from '../assets/images/dark/Webflow_dark.png';
import builderLight from '../assets/images/light/Builder logo light.png';
import builderDark from '../assets/images/dark/Builder logo dark.png';
import pangeaLight from '../assets/images/light/pangea-light.png';
import pangeaDark from '../assets/images/dark/pangea-dark.png';
import hereLogoLight from '../assets/images/light/HERE_logo.svg';
import hereLogoDark from '../assets/images/dark/HERE_logo_dark.svg';
import contentfulLight from '../assets/images/light/Contentful-light.png';
import contentfulDark from '../assets/images/dark/Contentful-dark-v2.png';

const { results } = seoData;

// Helper function to calculate stroke-dashoffset for progress rings
// Circle circumference = 2 * π * r = 2 * π * 30 = 188.5
function getStrokeDashoffset(score: number): number {
	const circumference = 188.5;
	return circumference - (circumference * score) / 100;
}
