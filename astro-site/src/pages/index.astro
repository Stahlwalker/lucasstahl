	<script>
		// Smooth scroll functionality for scroll indicator
		document.getElementById('scrollIndicator')?.addEventListener('click', function() {
			document.getElementById('claudeSection')?.scrollIntoView({
				behavior: 'smooth',
				block: 'start'
			});
		});

		// PostHog tracking for hero buttons
		document.addEventListener('DOMContentLoaded', function() {
			// Track View Resume button click
			const viewResumeBtn = document.getElementById('viewResumeBtn');
			if (viewResumeBtn) {
				viewResumeBtn.addEventListener('click', function() {
					if (window.posthog) {
						window.posthog.capture('resume_downloaded', {
							button_location: 'hero_section',
							button_text: 'View Resume'
						});
					}
				});
			}

			// Track Portfolio button click
			const portfolioBtn = document.getElementById('portfolioBtn');
			if (portfolioBtn) {
				portfolioBtn.addEventListener('click', function() {
					if (window.posthog) {
						window.posthog.capture('portfolio_clicked', {
							button_location: 'hero_section',
							button_text: 'Portfolio',
							destination: 'notion'
						});
					}
				});
			}

		// Filter functionality
		function initializeFilters() {
			const filterButtons = document.querySelectorAll('.filter-btn');
			const feedItems = document.querySelectorAll('.feed-item-link');

			// Add data attributes to cards based on their type badge
			feedItems.forEach(item => {
				const typeBadge = item.querySelector('.feed-type');
				if (typeBadge) {
					const typeText = typeBadge.textContent.trim().toLowerCase();
					item.setAttribute("data-type", typeText);
					console.log("Set data-type:", typeText, "on", item); // Debug log
				}
			});

			// Handle filter button clicks
			function handleFilterClick(button) {
				const filter = button.getAttribute("data-filter");
				const feedContainer = document.getElementById("feedContainer");

				console.log("Filtering by:", filter); // Debug log

				// Update active state
				filterButtons.forEach(btn => btn.classList.remove('active'));
				button.classList.add('active');

				// Filter cards
				let visibleCount = 0;
				feedItems.forEach(item => {
					const itemType = item.getAttribute("data-type");
					console.log("Item type:", itemType, "Filter:", filter, "Match:", filter === "all" || itemType === filter); // Debug log

					if (filter === 'all' || itemType === filter) {
						item.classList.remove('hidden');
						visibleCount++;
					} else {
						item.classList.add('hidden');
					}
				});

				console.log("Visible count:", visibleCount); // Debug log

				// Switch to single column when only 1 item visible
				if (visibleCount === 1) {
					feedContainer.classList.add('single-item');
				} else {
					feedContainer.classList.remove('single-item');
				}
			}

			filterButtons.forEach(button => {
				// Regular click for desktop
				button.addEventListener('click', function(e) {
					handleFilterClick(this);
				});

				// Touch event for mobile
				button.addEventListener('touchend', function(e) {
					e.preventDefault();
					e.stopPropagation();
					handleFilterClick(this);
				});
			});
		}

		// A/B Test: Sidebar Filter Layout
		// Wait for PostHog to load feature flags before checking
		if (window.posthog) {
			window.posthog.onFeatureFlags(function() {
				const highlightsWrapper = document.getElementById('highlightsWrapper');
				const variant = window.posthog.getFeatureFlag('highlights-layout-test');

				console.log('Feature flag loaded:', variant); // Debug log

				// Apply sidebar layout if test variant
				if (variant === 'test' && highlightsWrapper) {
					highlightsWrapper.classList.add('sidebar-layout');
					initializeFilters();
				}
			});
		}

		// Also initialize filters if sidebar is already present (for testing/debugging)
		setTimeout(function() {
			const highlightsWrapper = document.getElementById('highlightsWrapper');
			if (highlightsWrapper && highlightsWrapper.classList.contains('sidebar-layout')) {
				console.log('Sidebar detected, initializing filters');
				initializeFilters();
			}
		}, 500);

		// Expose filter initialization globally for testing
		window.initializeFilters = initializeFilters;
	});

	// Mobile/tablet logo marquee — JS-driven via requestAnimationFrame.
	// CSS keyframe animations cause a 1-frame flash on iOS WebKit at
	// every iteration boundary (the GPU layer gets re-rasterized when
	// the animation loops). Driving position via RAF + modulo wraps
	// continuously, so there's no boundary to flash on.
	(function setupMarquee() {
		const track = document.querySelector('.experience-marquee-track');
		if (!track) return;

		const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
		const smallViewport = window.matchMedia('(max-width: 1024px)');
		const tinyViewport = window.matchMedia('(max-width: 600px)');

		let rafId = null;
		let lastTime = null;
		let position = 0;

		function tick(now) {
			if (lastTime === null) lastTime = now;
			const dt = now - lastTime;
			lastTime = now;
			const duration = tinyViewport.matches ? 28000 : 32000;
			const halfWidth = track.scrollWidth / 2;
			if (halfWidth > 0) {
				position = (position + (dt / duration) * halfWidth) % halfWidth;
				track.style.transform = 'translate3d(' + (-position) + 'px, 0, 0)';
			}
			rafId = requestAnimationFrame(tick);
		}

		function start() {
			if (rafId !== null) return;
			track.style.animation = 'none';
			lastTime = null;
			rafId = requestAnimationFrame(tick);
		}

		function stop() {
			if (rafId !== null) {
				cancelAnimationFrame(rafId);
				rafId = null;
			}
			track.style.animation = '';
			track.style.transform = '';
			position = 0;
			lastTime = null;
		}

		function pause() {
			if (rafId !== null) {
				cancelAnimationFrame(rafId);
				rafId = null;
				lastTime = null;
			}
		}

		function evaluate() {
			if (document.hidden) {
				pause();
				return;
			}
			if (smallViewport.matches && !reduceMotion.matches) {
				start();
			} else {
				stop();
			}
		}

		smallViewport.addEventListener('change', evaluate);
		reduceMotion.addEventListener('change', evaluate);
		document.addEventListener('visibilitychange', evaluate);
		evaluate();
	})();

	// Command key — ⌘ symbols randomly surface and fade across the grid
	(function gridCommandKey() {
		if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

		const CELL = 24;
		const OFFSET = -1;

		const canvas = document.createElement('canvas');
		canvas.setAttribute('aria-hidden', 'true');
		canvas.style.cssText = 'position:fixed;inset:0;width:100%;height:100%;pointer-events:none;z-index:9998;';
		document.body.appendChild(canvas);

		const ctx = canvas.getContext('2d');

		function resize() {
			canvas.width = window.innerWidth;
			canvas.height = window.innerHeight;
		}
		resize();
		window.addEventListener('resize', resize);

		function isDark() {
			return document.documentElement.getAttribute('data-theme') !== 'light';
		}

		function updateBlend() {
			canvas.style.mixBlendMode = isDark() ? 'screen' : 'normal';
		}
		updateBlend();
		new MutationObserver(updateBlend).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

		const active = [];

		function addCell() {
			const cols = Math.ceil(canvas.width / CELL) + 1;
			const rows = Math.ceil(canvas.height / CELL) + 1;
			active.push({
				cx: OFFSET + Math.floor(Math.random() * cols) * CELL,
				cy: OFFSET + Math.floor(Math.random() * rows) * CELL,
				alpha: 0,
				phase: 'in',
				hold: 0,
			});
		}

		function drawSymbol(cx, cy, a, rgb) {
			ctx.save();
			ctx.font = '14px system-ui, -apple-system, sans-serif';
			ctx.fillStyle = `rgba(${rgb},${a * 0.9})`;
			ctx.shadowBlur = 10;
			ctx.shadowColor = `rgba(${rgb},${a * 0.6})`;
			ctx.textAlign = 'center';
			ctx.textBaseline = 'middle';
			ctx.fillText('⌘', cx + CELL / 2, cy + CELL / 2);
			ctx.restore();
		}

		const bolts = [];

		// Build a jagged lightning path from (x1,y1) to (x2,y2) along the grid
		function makePath(x1, y1, x2, y2) {
			const pts = [{x: x1, y: y1}];
			let cx = x1, cy = y1;
			let guard = 0;
			while ((cx !== x2 || cy !== y2) && guard++ < 400) {
				const dx = x2 - cx, dy = y2 - cy;
				// Random perpendicular jog for lightning feel
				if (Math.random() < 0.3 && Math.abs(dx) > CELL * 2 && Math.abs(dy) > CELL * 2) {
					const jog = (Math.random() < 0.5 ? 1 : -1) * CELL;
					if (Math.abs(dx) >= Math.abs(dy)) { cy += jog; }
					else { cx += jog; }
					pts.push({x: cx, y: cy});
				}
				// Step toward target on dominant axis
				if (Math.abs(x2 - cx) >= Math.abs(y2 - cy)) { cx += cx < x2 ? CELL : -CELL; }
				else { cy += cy < y2 ? CELL : -CELL; }
				pts.push({x: cx, y: cy});
			}
			return pts;
		}

		function draw(now) {
			checkHold(now);
			ctx.clearRect(0, 0, canvas.width, canvas.height);
			const rgb = isDark() ? '34,211,238' : '8,145,178';

			// Ambient ⌘ symbols
			for (let i = active.length - 1; i >= 0; i--) {
				const c = active[i];
				if (c.phase === 'in') {
					c.alpha = Math.min(1, c.alpha + 0.06);
					if (c.alpha === 1) c.phase = 'hold';
				} else if (c.phase === 'hold') {
					c.hold++;
					if (c.hold > 30) c.phase = 'out';
				} else {
					c.alpha = Math.max(0, c.alpha - 0.04);
					if (c.alpha === 0) { active.splice(i, 1); continue; }
				}
				drawSymbol(c.cx, c.cy, c.alpha, rgb);
			}

			// Electrical bolts
			for (let i = bolts.length - 1; i >= 0; i--) {
				const b = bolts[i];

				if (b.phase === 'travel') {
					b.progress = Math.min(b.pts.length - 1, b.progress + 2);
					if (b.progress >= b.pts.length - 1) {
						b.phase = 'hold';
						// Spawn ⌘ at destination
						const end = b.pts[b.pts.length - 1];
						active.push({ cx: end.x, cy: end.y, alpha: 0, phase: 'in', hold: 0 });
					}
				} else if (b.phase === 'hold') {
					b.hold++;
					if (b.hold > 20) b.phase = 'fade';
				} else {
					b.alpha = Math.max(0, b.alpha - 0.05);
					if (b.alpha === 0) { bolts.splice(i, 1); continue; }
				}

				const maxIdx = Math.floor(b.progress);
				if (maxIdx < 1) continue;

				ctx.save();
				ctx.strokeStyle = `rgba(${rgb},${b.alpha * 0.75})`;
				ctx.lineWidth = 1;
				ctx.shadowBlur = 10;
				ctx.shadowColor = `rgba(${rgb},${b.alpha * 0.5})`;
				ctx.beginPath();
				ctx.moveTo(b.pts[0].x, b.pts[0].y);
				for (let j = 1; j <= maxIdx; j++) ctx.lineTo(b.pts[j].x, b.pts[j].y);
				ctx.stroke();
				// Bright head at tip
				const tip = b.pts[maxIdx];
				ctx.fillStyle = `rgba(${rgb},${b.alpha})`;
				ctx.shadowBlur = 14;
				ctx.beginPath();
				ctx.arc(tip.x, tip.y, 2, 0, Math.PI * 2);
				ctx.fill();
				ctx.restore();
			}

			requestAnimationFrame(draw);
		}

		requestAnimationFrame(draw);

		function scheduleNext() {
			setTimeout(() => {
				if (!document.hidden) {
					const burst = Math.random() < 0.3 ? 2 : 1;
					for (let i = 0; i < burst; i++) addCell();
				}
				scheduleNext();
			}, 500 + Math.random() * 1000);
		}
		scheduleNext();

		// ⌘ hold — lightning scales with hold duration
		let cmdHeld = false, holdStart = 0, lastFire = 0;

		function fireLightning(intensity) {
			const originX = OFFSET + Math.round((canvas.width / 2 - OFFSET) / CELL) * CELL;
			const originY = OFFSET + Math.round((canvas.height / 2 - OFFSET) / CELL) * CELL;
			const cols = Math.ceil(canvas.width / CELL) + 1;
			const rows = Math.ceil(canvas.height / CELL) + 1;
			active.push({ cx: originX, cy: originY, alpha: 0, phase: 'in', hold: 0 });
			const count = intensity === 'low' ? 3 : intensity === 'mid' ? 5 : 8;
			for (let b = 0; b < count; b++) {
				const tx = OFFSET + Math.floor(Math.random() * cols) * CELL;
				const ty = OFFSET + Math.floor(Math.random() * rows) * CELL;
				bolts.push({ pts: makePath(originX, originY, tx, ty), progress: 0, alpha: 1, phase: 'travel', hold: 0 });
			}
		}

		// In the rAF loop we check hold state — integrated by calling checkHold() in draw
		function checkHold(now) {
			if (!cmdHeld) return;
			const held = now - holdStart;
			const interval = held < 400 ? 350 : held < 900 ? 220 : 130;
			if (now - lastFire < interval) return;
			lastFire = now;
			fireLightning(held < 400 ? 'low' : held < 900 ? 'mid' : 'high');
		}

		window.addEventListener('keydown', (e) => {
			if (e.key !== 'Meta') return;
			if (!cmdHeld) { cmdHeld = true; holdStart = performance.now(); lastFire = 0; fireLightning('low'); }
		});
		window.addEventListener('keyup', (e) => { if (e.key === 'Meta') cmdHeld = false; });
	})();
</script>
</Layout>
