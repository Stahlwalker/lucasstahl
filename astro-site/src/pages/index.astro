	<style>
		/* Experience Strip — centered title above boxed logo grid with wave-tilt */
		.experience-strip {
			padding: 5rem 1rem 4.5rem;
			position: relative;
			overflow: hidden;
		}

		.experience-strip-container {
			max-width: 900px;
			margin: 0 auto 1.75rem;
			text-align: center;
			position: relative;
			z-index: 1;
		}

		.experience-strip-title {
			font-family: 'Inter', system-ui, sans-serif;
			font-size: 0.78rem;
			font-weight: 600;
			line-height: 1.4;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			color: #94a3b8;
			margin: 0;
		}

		:global([data-theme="light"]) .experience-strip-title {
			color: #64748b;
		}

		.experience-strip-grid {
			max-width: 1280px;
			margin: 0 auto;
			border-top: 1px solid rgba(148, 163, 184, 0.2);
			border-bottom: 1px solid rgba(148, 163, 184, 0.2);
			overflow: hidden;
		}

		.experience-marquee-track {
			display: grid;
			grid-template-columns: repeat(5, 1fr);
			align-items: stretch;
		}

		:global([data-theme="light"]) .experience-strip-grid {
			border-top-color: rgba(15, 23, 42, 0.2);
			border-bottom-color: rgba(15, 23, 42, 0.2);
		}

		.experience-logo-cell {
			position: relative;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			min-height: 160px;
			padding: 2rem 1.5rem;
			border-left: 1px solid rgba(148, 163, 184, 0.18);
			overflow: hidden;
			isolation: isolate;
			transition: background-color 0.4s ease;
		}

		.experience-logo-cell:first-child {
			border-left: none;
		}

		:global([data-theme="light"]) .experience-logo-cell {
			border-left-color: rgba(15, 23, 42, 0.2);
		}

		/* Halftone dot pattern fading from top — hidden until hover */
		.experience-logo-cell::before {
			content: '';
			position: absolute;
			inset: 0;
			background-image: radial-gradient(
				circle at center,
				rgb(var(--cell-color, 34 211 238) / 0.85) 1px,
				transparent 1.6px
			);
			background-size: 11px 11px;
			-webkit-mask-image: linear-gradient(180deg, black 0%, rgba(0, 0, 0, 0.7) 30%, transparent 75%);
			mask-image: linear-gradient(180deg, black 0%, rgba(0, 0, 0, 0.7) 30%, transparent 75%);
			opacity: 0;
			transition: opacity 0.45s cubic-bezier(0.4, 0, 0.2, 1);
			pointer-events: none;
			z-index: 0;
		}

		.experience-logo-cell:hover::before {
			opacity: 1;
		}

		.experience-logo-cell:hover {
			background-color: rgb(var(--cell-color, 34 211 238) / 0.04);
		}

		.experience-logo-flip {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			position: relative;
			z-index: 1;
		}

		@media (prefers-reduced-motion: reduce) {
			.experience-logo-cell::before {
				transition: none;
			}
		}

		.experience-logo {
			max-height: 30px;
			max-width: 100%;
			width: auto;
			height: auto;
			object-fit: contain;
		}

		.experience-logo-cell--icon .experience-logo {
			max-height: 48px;
		}

		/* Light pangea PNG is tightly cropped (no padding), while the dark PNG
		   has whitespace baked in. Cap the light variant so the visible text
		   matches dark-mode rendering. */
		.experience-logo-cell--pangea .logo-light {
			max-height: 23px;
		}

		/* Light/dark logo swapping */
		.experience-logo-cell .logo-dark { display: inline-block; }
		.experience-logo-cell .logo-light { display: none; }
		:global([data-theme="light"]) .experience-logo-cell .logo-dark { display: none; }
		:global([data-theme="light"]) .experience-logo-cell .logo-light { display: inline-block; }

		/* Cloned cells used only by the mobile marquee — hidden on desktop.
		   This rule must come AFTER the base .experience-logo-cell rule to override its display:flex. */
		.experience-logo-cell--clone {
			display: none;
		}

		/* Tablet + mobile: switch from static grid to horizontal scrolling marquee.
		   Threshold covers iPad Pro portrait (1024px) and below. Hover doesn't exist
		   reliably on touch, so the static halftone-on-hover loses its purpose —
		   motion fills the gap. */
		@media (max-width: 1024px) {
			.experience-strip {
				padding: 3rem 0 2.5rem;
			}
			.experience-marquee-track {
				display: flex;
				flex-wrap: nowrap;
				width: max-content;
				align-items: center;
				/* CSS animation is the no-JS fallback. The page script
				   (see end of file) takes over with a requestAnimationFrame
				   loop on small viewports — iOS WebKit re-rasterizes the
				   GPU layer at every CSS keyframe iteration boundary,
				   producing a ~1-frame flash every loop. RAF avoids the
				   boundary entirely by wrapping position via modulo. */
				animation: marquee-scroll 32s linear infinite;
				will-change: transform;
			}
			.experience-logo-cell {
				flex: 0 0 auto;
				width: 22vw;
				min-height: 100px;
				padding: 1.25rem 1rem;
			}
			/* Restore border-left on the first cell so its visual matches the
			   cloned Webflow cell. Without this, the marquee loop snap creates
			   a 1px flicker on the left edge each time it wraps. */
			.experience-logo-cell:first-child {
				border-left: 1px solid rgba(148, 163, 184, 0.18);
			}
			:global([data-theme="light"]) .experience-logo-cell:first-child {
				border-left-color: rgba(15, 23, 42, 0.2);
			}
			.experience-logo-cell--clone {
				display: flex;
			}
			.experience-logo {
				max-height: 24px;
				max-width: 130px;
			}
			.experience-logo-cell--icon .experience-logo {
				max-height: 44px;
				max-width: 44px;
			}
			.experience-logo-cell--pangea .logo-light {
				max-height: 20px;
				max-width: 96px;
			}
			/* Hover halftone has no purpose on touch */
			.experience-logo-cell::before {
				display: none;
			}
		}

		/* Mobile: tighter cells, faster loop, smaller logos */
		@media (max-width: 600px) {
			.experience-strip {
				padding: 2.25rem 0 2rem;
			}
			.experience-strip-container {
				margin-bottom: 1rem;
			}
			.experience-strip-title {
				font-size: 0.7rem;
				letter-spacing: 0.12em;
				padding: 0 0.5rem;
			}
			.experience-marquee-track {
				animation-duration: 28s;
			}
			.experience-logo-cell {
				width: 38vw;
				min-height: 80px;
				padding: 1rem 0.5rem;
			}
			.experience-logo {
				max-height: 16px;
				max-width: 100px;
			}
			.experience-logo-cell--icon .experience-logo {
				max-height: 36px;
				max-width: 36px;
			}
			.experience-logo-cell--pangea .logo-light {
				max-height: 13px;
				max-width: 64px;
			}
		}

		@keyframes marquee-scroll {
			from { transform: translateX(0); }
			to { transform: translateX(-50%); }
		}

		@media (max-width: 1024px) and (prefers-reduced-motion: reduce) {
			.experience-marquee-track {
				animation: none;
				width: 100%;
				justify-content: space-around;
			}
			.experience-logo-cell--clone {
				display: none;
			}
			.experience-logo-cell {
				width: auto;
				flex: 1 1 0;
			}
		}

