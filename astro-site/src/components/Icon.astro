---
/**
 * Inline SVG icon component backed by the files in /src/icons/.
 * Usage: <Icon name="brain" /> or <Icon name="github" />
 *
 * Files are loaded eagerly at build time via Vite's import.meta.glob with
 * ?raw, so each icon usage inlines the SVG markup with no runtime cost
 * and no external request.
 */

interface Props {
  name: string;
  class?: string;
  /** Inline style overrides — useful for one-off sizing. */
  style?: string;
  /** Accessibility: set when the icon conveys meaning on its own. */
  ariaLabel?: string;
  /** Optional element id (used by JS toggles like the theme switcher). */
  id?: string;
}

const { name, class: className, style, ariaLabel, id } = Astro.props;

const icons = import.meta.glob('/src/icons/*.svg', {
  eager: true,
  query: '?raw',
  import: 'default',
}) as Record<string, string>;

// File naming: `<name>-solid-full.svg` or `<name>-brands-solid-full.svg`.
// Match exactly — without anchoring the variant suffix, `pen` would also
// match `pen-fancy-solid-full.svg` since both start with `pen-`.
const expectedNames = [
  `${name}-solid-full.svg`,
  `${name}-brands-solid-full.svg`,
  `${name}-regular-full.svg`,
];
const entry = Object.entries(icons).find(([path]) => {
  const base = path.split('/').pop() ?? '';
  return expectedNames.includes(base);
});

if (!entry && !import.meta.env.SSR) {
  console.warn(`[Icon] No SVG found for name "${name}"`);
}

// Inject `width="1em" height="1em"` directly on the <svg> element so the
// browser knows the icon size from the HTML alone — without these attrs the
// SVG would briefly paint at its intrinsic 640×640 viewBox before CSS rules
// shrink it (the FOUC Luke saw on /seo/). Any per-context CSS override
// (e.g. `.vitals-card h3 .icon-svg svg { width: 1.55rem }`) still wins.
const rawSvg = entry?.[1] ?? '';
const svg = rawSvg.replace('<svg ', '<svg width="1em" height="1em" ');
---

<span
  class:list={['icon-svg', className]}
  style={style}
  id={id}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
  set:html={svg}
/>

<!-- Base .icon-svg CSS lives in public/assets/css/style.css so it's inlined
     in <head> via inlineCriticalCSS and no FOUC happens on first paint. -->

